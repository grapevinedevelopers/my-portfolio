rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Site-aware structure: all data lives under /sites/{siteId}/...
    match /sites/{siteId} {

      // Personal details: public read for 'main' doc, write requires auth
      match /personalDetails/{docId} {
        allow read: if docId == 'main';
        allow write: if request.auth != null && docId == 'main';
      }

      // Blog posts: public read, write requires auth
      match /blogPosts/{postId} {
        allow read: if true;
        allow write: if request.auth != null;
      }

      // Projects: public read, write requires auth
      match /projects/{projectId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
