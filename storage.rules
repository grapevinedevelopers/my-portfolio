rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read access to all files (adjust if needed for privacy)
    // Match any file in any path
    match /{allPaths=**} {
      allow read: if true;
    }

    // Allow authenticated users to write (upload, update, delete)
    // only within the 'projectImages' folder structure.
    // This assumes you organize images by projectId.
    match /projectImages/{projectId}/{allImages=**} {
       // Allow write operations (create, update, delete) only if the user is authenticated.
       // You might want to add more specific rules, e.g., linking to Firestore document ownership,
       // but this is a basic rule to enable uploads for logged-in users.
      allow write: if request.auth != null;
    }

    // Deny write access to any other path by default if not explicitly allowed above.
    // Add other match statements here if needed for other storage paths.
  }
}
